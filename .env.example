# SatNOGS API keys. Find them on your account pages after logging in:
#   - satnogs_network_api_key : https://network.satnogs.org  (used for the observations API)
#   - satnogs_db_api_key      : https://db.satnogs.org        (used for satellite/transmitter metadata)
# Copy this file to `.env` (gitignored — your keys stay out of git) and fill them in.
# Tools load it via:  set -a; source .env; set +a
satnogs_network_api_key=
satnogs_db_api_key=

# Hugging Face token with WRITE access — from https://huggingface.co/settings/tokens
# Needed to push the dataset (and later the model) to the Hub under your account.
HF_TOKEN=
